---
import BaseLayout from "../layouts/BaseLayout.astro";
import aboutRaw from "../content/about.md?raw";
import { frontmatter as about } from "../content/about.md";

const base = import.meta.env.BASE_URL;

type AboutLink = {
  label: string;
  href?: string;
};

type AboutFrontmatter = {
  title: string;
  eyebrow?: string;
  description?: string;
  links?: AboutLink[];
};

type Card = {
  title: string;
  text: string;
};

type SkillGroup = {
  title: string;
  items: string[];
};

type TimelineItem = {
  title: string;
  time: string;
  detail: string;
};

type ExperienceItem = {
  title: string;
  meta: string;
  points: string[];
};

function stripFrontmatter(markdown: string) {
  return markdown.replace(/^---\r?\n[\s\S]*?\r?\n---\r?\n?/, "");
}

function getSection(markdown: string, title: string) {
  const pattern = new RegExp(`^##\\s+${title.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}\\s*$`, "m");
  const match = markdown.match(pattern);
  if (!match || match.index === undefined) return "";

  const start = match.index + match[0].length;
  const rest = markdown.slice(start);
  const next = rest.search(/^##\s+/m);
  return (next === -1 ? rest : rest.slice(0, next)).trim();
}

function splitCards(section: string) {
  const matches = [...section.matchAll(/^###\s+(.+)$/gm)];
  return matches.map((match, index) => {
    const next = matches[index + 1];
    const start = (match.index ?? 0) + match[0].length;
    const end = next?.index ?? section.length;
    return {
      title: match[1].trim(),
      body: section.slice(start, end).trim(),
    };
  });
}

function parseList(body: string) {
  return body
    .split(/\r?\n/)
    .map((line) => line.trim().replace(/^[-*]\s+/, ""))
    .filter(Boolean);
}

function parseFieldBody(body: string, fieldName = "时间") {
  const lines = body.split(/\r?\n/).map((line) => line.trim()).filter(Boolean);
  const fieldPrefix = `${fieldName}:`;
  const fieldIndex = lines.findIndex((line) => line.startsWith(fieldPrefix));
  const field = fieldIndex === -1 ? "" : lines[fieldIndex].slice(fieldPrefix.length).trim();
  const contentLines = lines.filter((_, index) => index !== fieldIndex);
  return { field, contentLines };
}

const aboutData = about as AboutFrontmatter;
const aboutContent = stripFrontmatter(aboutRaw);

const overview: Card[] = splitCards(getSection(aboutContent, "个人概况")).map((card) => ({
  title: card.title,
  text: card.body.replace(/\r?\n+/g, " "),
}));

const skills: SkillGroup[] = splitCards(getSection(aboutContent, "技术栈")).map((card) => ({
  title: card.title,
  items: parseList(card.body),
}));

const education: TimelineItem[] = splitCards(getSection(aboutContent, "教育背景")).map((card) => {
  const { field, contentLines } = parseFieldBody(card.body);
  return {
    title: card.title,
    time: field,
    detail: contentLines.join(" "),
  };
});

const experiences: ExperienceItem[] = splitCards(getSection(aboutContent, "研究、项目与实习")).map((card) => {
  const { field, contentLines } = parseFieldBody(card.body);
  return {
    title: card.title,
    meta: field,
    points: parseList(contentLines.join("\n")),
  };
});
---

<BaseLayout title={`${aboutData.title} | 猫箱`}>
  <a class="back-link page-back" href={base}>返回首页</a>

  <section class="about-hero">
    <p class="eyebrow">{aboutData.eyebrow ?? "About"}</p>
    <h1>{aboutData.title}</h1>
    {aboutData.description && <p>{aboutData.description}</p>}
    <div class="about-links">
      {(aboutData.links ?? []).map((link) =>
        link.href ? <a href={link.href}>{link.label}</a> : <span>{link.label}</span>
      )}
    </div>
  </section>

  <section class="about-grid" aria-label="个人概况">
    {overview.map((item) => (
      <article class="about-card">
        <h2>{item.title}</h2>
        <p>{item.text}</p>
      </article>
    ))}
  </section>

  <section class="about-section">
    <h2>技术栈</h2>
    <div class="skill-grid">
      {skills.map((group) => (
        <article class="skill-card">
          <h3>{group.title}</h3>
          <div class="tag-list">
            {group.items.map((item) => <span>{item}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="about-section">
    <h2>教育背景</h2>
    <div class="timeline">
      {education.map((item) => (
        <article class="timeline-item">
          <div>
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </div>
          <time>{item.time}</time>
        </article>
      ))}
    </div>
  </section>

  <section class="about-section">
    <h2>研究、项目与实习</h2>
    <div class="experience-list">
      {experiences.map((item) => (
        <article class="experience-card">
          <p class="experience-meta">{item.meta}</p>
          <h3>{item.title}</h3>
          <ul>
            {item.points.map((point) => <li>{point}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
