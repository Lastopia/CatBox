---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="猫箱">
  <section class="hero">
    <p class="eyebrow">Catbox Personal Site</p>
    <h1>猫箱</h1>
    <p class="intro">一个装着个人简介、笔记本、作品和灵感的小型个人网站。</p>
    <div class="actions">
      <a href={`${base}notebooks/`}>进入笔记本</a>
      <a href={`${base}about/`}>关于我</a>
    </div>
  </section>

  <section class="notice-board" aria-label="公告栏">
    <div class="notice-pin"></div>
    <p class="eyebrow">Notice</p>
    <h2>公告栏</h2>
    <p>猫箱正在搭建中。这里以后可以放网站更新、近期计划、想写给访客的话，或者提醒自己继续维护的小纸条。</p>
    <ul>
      <li>笔记本区域已经开放，内容会慢慢补上。</li>
      <li>关于我页面还是草稿，后面会换成真实介绍。</li>
      <li>背景视频和页面风格还会继续调整。</li>
    </ul>
  </section>
</BaseLayout>
