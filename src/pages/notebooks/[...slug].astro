---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getNotebook } from "../../data/notebooks";

type NoteModule = {
  Content: unknown;
  frontmatter: {
    title: string;
    date: string;
    notebook: string;
    description?: string;
    coreIdeas?: string[];
  };
};

export function getStaticPaths() {
  const noteModules = import.meta.glob<NoteModule>("../../content/notes/**/*.md", {
    eager: true,
  });

  return Object.entries(noteModules).map(([path, note]) => {
    const slug = path.replace("../../content/notes/", "").replace(/\.md$/, "");

    return {
      params: { slug },
      props: { note },
    };
  });
}

const { note } = Astro.props;
const { Content } = note;
const notebookSlug = Astro.params.slug?.split("/")[0] ?? "";
const notebook = getNotebook(notebookSlug);
const base = import.meta.env.BASE_URL;
const displayDate = new Date(note.frontmatter.date).toISOString().slice(0, 10);
const coreIdeas = note.frontmatter.coreIdeas ?? [];
---

<BaseLayout title={`${note.frontmatter.title} | 猫箱`}>
  <article class="note-article">
    <a class="back-link" href={`${base}notebooks/${notebookSlug}/`}>返回{notebook?.name ?? "笔记本"}</a>
    <header>
      <p class="eyebrow">{note.frontmatter.notebook}</p>
      <time datetime={displayDate}>{displayDate}</time>
      <h1>{note.frontmatter.title}</h1>
      {note.frontmatter.description && <p>{note.frontmatter.description}</p>}
    </header>
    {coreIdeas.length > 0 && (
      <section class="core-ideas-card" aria-labelledby="core-ideas-title">
        <p class="eyebrow">Highlights</p>
        <h2 id="core-ideas-title">核心观点</h2>
        <ul>
          {coreIdeas.map((idea) => <li>{idea}</li>)}
        </ul>
      </section>
    )}
    <div class="note-body-card prose">
      <Content />
    </div>
  </article>
</BaseLayout>
